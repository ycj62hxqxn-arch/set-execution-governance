async function runAI() {
  const input = document.getElementById("userInput").value;
  const log = document.getElementById("log");

  log.innerHTML = "";

  function step(text, delay = 800, className="step") {
    return new Promise(resolve => {
      setTimeout(() => {
        const div = document.createElement("div");
        div.className = className;
        div.innerText = text;
        log.appendChild(div);
        log.scrollTop = log.scrollHeight;
        resolve();
      }, delay);
    });
  }

  await step("Parsing input...");
  await step("Applying logic engine...");
  await step("Evaluating rules...");

  // API CALL
  const res = await fetch("http://localhost:3000/execute", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ input })
  });

  const data = await res.json();

  await step("Authority Gate (QGED)...");

  if (data.status === "blocked") {
    await step("❌ BLOCKED: " + data.reason, 600, "blocked");
  } else {
    await step("✔ APPROVED", 600, "approved");

    await step("Generating controlled response...", 800);

    const div = document.createElement("div");
    div.innerHTML = "<br>" + data.output;
    log.appendChild(div);
  }
}